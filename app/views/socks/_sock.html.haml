%div{id: dom_id(sock), class: ["sock", is_matched_class(sock)].compact}
  %p
    %strong Name:
    = sock.name

  %p
    %strong Description:
    = sock.description

  %p
    %strong Gender:
    = sock.gender

  %p
    %strong Age:
    = sock.age

  %p
    %strong Height:
    = sock.height

  %p
    %strong Color:
    = sock.color

  .actions
    = link_to 'Edit', edit_sock_path(sock), class: 'btn btn-primary'
    = button_to 'Delete', sock_path(sock), method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-danger'